# PostgreSQL (локально или на VPS)
DATABASE_URL=postgresql://sputnik:sputnik_password@localhost:5432/sputnik

# Публичный URL приложения (для OAuth redirect)
APP_URL=https://your-domain.com

# Telegram Bot (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=WeGoWithSputnik_bot

# Google Fit OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=https://your-domain.com/api/google-fit/callback

# Ключ для админ-API промокодов (заголовок x-admin-key)
ADMIN_API_KEY=your_admin_key

# Порт для production (VPS)
PORT=3000
